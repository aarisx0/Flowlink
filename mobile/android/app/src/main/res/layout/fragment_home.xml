<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- Top Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <ImageButton
                    android:id="@+id/btn_hamburger"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/glass_card_bg_dark"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    android:tint="#FFFFFF"
                    android:padding="8dp"
                    android:contentDescription="Menu" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Connected Devices"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Collaborate and connect seamlessly"
                        android:textColor="#B8B5D4"
                        android:textSize="12sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_invite_others"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Invite Others"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_primary_bg"
                    android:paddingHorizontal="14dp" />
            </LinearLayout>

            <!-- Session Code Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/glass_card_bg"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Session Code"
                        android:textColor="#B8B5D4"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tv_session_code"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="------"
                        android:textColor="#6C63FF"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2" />
                </LinearLayout>

                <!-- Connection status + reconnect -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/tv_status_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● Connected"
                        android:textColor="#22C55E"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <Button
                        android:id="@+id/btn_reconnect"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:text="↺ Reconnect"
                        android:textSize="11sp"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_ghost_bg"
                        android:paddingHorizontal="10dp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/glass_card_bg_dark"
                    android:padding="12dp"
                    android:gravity="center"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tv_stat_active"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#22C55E"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active"
                        android:textColor="#B8B5D4"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/glass_card_bg_dark"
                    android:padding="12dp"
                    android:gravity="center"
                    android:layout_marginHorizontal="3dp">

                    <TextView
                        android:id="@+id/tv_stat_files"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#F59E0B"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Files"
                        android:textColor="#B8B5D4"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/glass_card_bg_dark"
                    android:padding="12dp"
                    android:gravity="center"
                    android:layout_marginHorizontal="3dp">

                    <TextView
                        android:id="@+id/tv_stat_messages"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#3B82F6"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Messages"
                        android:textColor="#B8B5D4"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/glass_card_bg_dark"
                    android:padding="12dp"
                    android:gravity="center"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:id="@+id/tv_stat_online"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#A78BFA"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Online"
                        android:textColor="#B8B5D4"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Devices Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Devices"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_devices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="20dp" />

            <!-- Store Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Store"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_store_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 files"
                    android:textColor="#B8B5D4"
                    android:textSize="12sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_store_files"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_study_store"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No files in store yet. Go to Files tab to upload."
                android:textColor="#6B6890"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingVertical="16dp"
                android:background="@drawable/glass_card_bg_dark"
                android:visibility="visible" />

        </LinearLayout>
    </ScrollView>

    <!-- Drawer overlay -->
    <FrameLayout
        android:id="@+id/drawer_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone" />

    <!-- Side Drawer -->
    <LinearLayout
        android:id="@+id/side_drawer"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#1E1A3E"
        android:translationX="-280dp"
        android:elevation="16dp"
        android:paddingTop="56dp"
        android:paddingHorizontal="20dp"
        android:paddingBottom="24dp">

        <!-- Profile Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/glass_card_bg_dark"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="14dp">

                <View
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/share_fab_bg" />

                <TextView
                    android:id="@+id/tv_avatar_initial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="U"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_drawer_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Online"
                    android:textColor="#22C55E"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Drawer Menu Items -->
        <TextView
            android:id="@+id/drawer_session_details"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📋  Session Details"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="@drawable/glass_card_bg_dark"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/drawer_permissions"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🔒  Permissions"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="@drawable/glass_card_bg_dark"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/drawer_settings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="⚙️  Settings"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="@drawable/glass_card_bg_dark"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/drawer_help"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="❓  Help &amp; Support"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="@drawable/glass_card_bg_dark"
            android:layout_marginBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginVertical="12dp" />

        <TextView
            android:id="@+id/drawer_leave_session"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🚪  Leave Session"
            android:textColor="#EF4444"
            android:textSize="15sp"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="@drawable/btn_danger_bg" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
