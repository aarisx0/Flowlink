<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/glass_card_bg_dark"
    android:padding="14dp"
    android:layout_marginBottom="8dp">

    <!-- Avatar -->
    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="12dp">

        <View
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/share_fab_bg"
            android:alpha="0.3" />

        <TextView
            android:id="@+id/tv_friend_initial"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="U"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_friend_username"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Username"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_friend_device"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device"
            android:textColor="#B8B5D4"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Remove -->
    <ImageButton
        android:id="@+id/btn_remove_friend"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/btn_danger_bg"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="#EF4444"
        android:padding="6dp"
        android:contentDescription="Remove friend" />

</LinearLayout>
