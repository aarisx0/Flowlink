<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="20dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shared Files"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_files_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All session members can access"
                android:textColor="#B8B5D4"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Sync toggle -->
        <ImageButton
            android:id="@+id/btn_sync_toggle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/glass_card_bg_dark"
            android:src="@android:drawable/ic_menu_share"
            android:tint="#22C55E"
            android:padding="6dp"
            android:contentDescription="Sync toggle"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_select_files"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Select Files"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:background="@drawable/btn_primary_bg"
            android:paddingHorizontal="14dp" />
    </LinearLayout>

    <!-- Study Sync Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/glass_card_bg_dark"
        android:paddingHorizontal="18dp"
        android:paddingVertical="12dp"
        android:layout_marginHorizontal="14dp"
        android:layout_marginBottom="14dp">

        <Button
            android:id="@+id/btn_study_prev"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="◀"
            android:textAllCaps="false"
            android:textColor="#B8B5D4"
            android:background="@drawable/btn_ghost_bg"
            android:paddingHorizontal="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginHorizontal="12dp">

            <TextView
                android:id="@+id/tv_study_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Page 1"
                android:textColor="#A78BFA"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_gravity="center" />

            <TextView
                android:id="@+id/tv_sync_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Synced with all devices"
                android:textColor="#6B6890"
                android:textSize="11sp"
                android:layout_gravity="center" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_study_next"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="▶"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_primary_bg"
            android:paddingHorizontal="16dp" />
    </LinearLayout>

    <!-- Files List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_files"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="14dp"
        android:paddingBottom="14dp"
        android:clipToPadding="false" />

</LinearLayout>
