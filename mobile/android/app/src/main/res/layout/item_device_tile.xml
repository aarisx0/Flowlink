<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/glass_card_bg"
    android:padding="16dp"
    android:layout_marginBottom="10dp">

    <!-- Top Row: Name + Status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <View
            android:id="@+id/online_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/online_dot"
            android:layout_marginEnd="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/device_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Device Name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/device_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Device Type"
                android:textSize="12sp"
                android:textColor="#B8B5D4" />
        </LinearLayout>

        <TextView
            android:id="@+id/device_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Online"
            android:textSize="12sp"
            android:textColor="#22C55E"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Permissions -->
    <TextView
        android:id="@+id/device_permissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No permissions"
        android:textSize="11sp"
        android:textColor="#6B6890"
        android:layout_marginBottom="10dp" />

    <!-- Transfer Progress -->
    <LinearLayout
        android:id="@+id/transfer_status_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/glass_card_bg_dark"
        android:padding="10dp"
        android:layout_marginBottom="10dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tv_transfer_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sending file"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tv_transfer_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="13sp"
                android:textColor="#A78BFA"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/transfer_progress_bar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:progressDrawable="@drawable/progress_bar_track"
            android:max="100"
            android:progress="0" />

        <TextView
            android:id="@+id/tv_transfer_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="0 B / 0 B · ETA 00:00"
            android:textSize="10sp"
            android:textColor="#6B6890" />
    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btn_browse_files"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Select Files"
            android:textSize="12sp"
            android:paddingHorizontal="14dp"
            android:background="@drawable/button_browse_files"
            android:textColor="#A78BFA"
            android:textAllCaps="false"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_tap_hint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tap to send clipboard"
            android:textSize="11sp"
            android:textColor="#6B6890"
            android:gravity="center_vertical" />
    </LinearLayout>

</LinearLayout>
