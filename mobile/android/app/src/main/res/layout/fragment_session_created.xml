<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="28dp"
        android:paddingTop="72dp"
        android:paddingBottom="48dp">

        <!-- QR Code Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/glass_card_bg"
            android:padding="28dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Share QR Code"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan to connect devices"
                android:textColor="#B8B5D4"
                android:textSize="13sp"
                android:layout_marginBottom="20dp" />

            <ImageView
                android:id="@+id/qr_code_image"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:background="@drawable/glass_card_bg_dark"
                android:padding="8dp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:id="@+id/session_code_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Session Code"
                android:textColor="#B8B5D4"
                android:textSize="13sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/session_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#6C63FF"
                android:letterSpacing="0.3" />
        </LinearLayout>

        <!-- Waiting indicator -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/glass_card_bg_dark"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳  Waiting for devices to connect…"
                android:textColor="#B8B5D4"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/done_button"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Continue to Session"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:background="@drawable/btn_primary_bg" />

    </LinearLayout>
</ScrollView>
