<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/glass_card_bg_dark"
                android:src="@android:drawable/ic_menu_revert"
                android:tint="#FFFFFF"
                android:padding="8dp"
                android:contentDescription="Back"
                android:layout_marginEnd="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Help &amp; Support"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- How to Use -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_bg"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📖  How to Use FlowLink"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Create or join a session using a 6-digit code or QR scan.\n\n2. Home — See all connected devices and session stats.\n\n3. Chat — Send messages, files, and reply to messages.\n\n4. Share — Tap a device to send clipboard content, or use Select Files.\n\n5. Files — Upload files to the shared study store. All members can access them.\n\n6. More — Manage groups, settings, and session options."
                android:textColor="#B8B5D4"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.5" />
        </LinearLayout>

        <!-- Report Issue -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_bg"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐛  Report an Issue"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/et_report"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/input_glass_bg"
                android:hint="Describe the issue..."
                android:textColor="#FFFFFF"
                android:textColorHint="#6B6890"
                android:textSize="13sp"
                android:padding="12dp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btn_submit_report"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Submit Report"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:background="@drawable/btn_primary_bg" />
        </LinearLayout>

        <!-- Feedback -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_bg"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬  Send Feedback"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/et_feedback"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/input_glass_bg"
                android:hint="Share your thoughts..."
                android:textColor="#FFFFFF"
                android:textColorHint="#6B6890"
                android:textSize="13sp"
                android:padding="12dp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btn_submit_feedback"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Send Feedback"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:background="@drawable/btn_primary_bg" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
